// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  CUSTOMER
  ADMIN
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(CUSTOMER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  orders       Order[]
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  createdAt DateTime @default(now())
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
}

model UploadedImage {
  id        String   @id @default(cuid())
  data      Bytes
  mimeType  String
  createdAt DateTime @default(now())
}

model Product {
  id             String   @id @default(cuid())
  slug           String   @unique
  name           String
  category       String
  price          Int
  compareAtPrice Int?
  image          String
  description    String
  finish         String
  collections    String[] @default([])
  isNew          Boolean  @default(false)
  stock          Int      @default(20)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  orderItems     OrderItem[]
  reviews        Review[]
}

model Review {
  id         String   @id @default(cuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  authorName String
  rating     Int
  comment    String
  createdAt  DateTime @default(now())
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  COD
  BANK_TRANSFER
}

model Order {
  id            String        @id @default(cuid())
  orderNumber   String        @unique
  status        OrderStatus   @default(PENDING)
  paymentMethod PaymentMethod
  customerName  String
  email         String
  phone         String
  address       String
  city          String
  notes         String?
  subtotal      Int
  total         Int
  userId        String?
  user          User?         @relation(fields: [userId], references: [id])
  items         OrderItem[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model OrderItem {
  id           String   @id @default(cuid())
  orderId      String
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId    String?
  product      Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  productName  String
  productImage String
  unitPrice    Int
  quantity     Int
  lineTotal    Int
}
